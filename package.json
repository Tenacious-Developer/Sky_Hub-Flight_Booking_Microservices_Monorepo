{
  "name": "skyhub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:user": "turbo run dev --filter=@skyhub/user-service",
    "dev:flight": "turbo run dev --filter=@skyhub/flight-service",
    "db:migrate:flight": "npm run db:migrate -w @skyhub/flight-service",
    "db:generate:flight": "npm run db:generate -w @skyhub/flight-service",
    "db:push:flight": "npm run db:push -w @skyhub/flight-service",
    "db:studio:flight": "npm run db:studio -w @skyhub/flight-service",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
