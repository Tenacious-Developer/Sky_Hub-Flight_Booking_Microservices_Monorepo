{
  "name": "@skyhub/user-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --clean --minify",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:migrate": "prisma migrate dev --config src/config/prisma.config.ts",
    "db:generate": "prisma generate --config src/config/prisma.config.ts",
    "db:push": "prisma db push --config src/config/prisma.config.ts",
    "db:studio": "prisma studio --config src/config/prisma.config.ts",
    "db:deploy": "prisma migrate deploy --config src/config/prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@skyhub/common-utils": "*",
    "@skyhub/shared-types": "*",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1"
  }
}